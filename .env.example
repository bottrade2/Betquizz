# ── Backend ───────────────────────────────────────────────────────────────────
PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=betquizz

# Generate with: node -e "require('crypto').randomBytes(48).toString('hex')|Write-Output"
JWT_SECRET=replace_with_a_long_random_secret_at_least_48_chars

# URL of the deployed frontend (used by CORS and Stripe redirects)
CLIENT_URL=https://yourdomain.com

# ── Stripe (optional — coin purchases) ───────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ── Frontend (.env in frontend/ folder) ──────────────────────────────────────
REACT_APP_API_URL=https://yourdomain.com/api
REACT_APP_SOCKET_URL=https://yourdomain.com
